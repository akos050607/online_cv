---
import "../styles/global.css";
import SystemCore from "../components/SystemCore.jsx";
import ProfileHologram from "../components/ProfileHologram.jsx";
---

<html lang="hu">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Kovács János - System</title>
	</head>
	<body class="relative selection:bg-nothing-red selection:text-white text-black bg-[#f4f4f4]">
		
		<div class="dot-grid-overlay"></div>

		<main class="relative z-10 flex flex-col">

			<section class="min-h-[100dvh] w-full flex items-center justify-center p-6 md:p-12">
				<div class="max-w-[90rem] w-full grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
					
					<div class="bg-white/60 backdrop-blur-md border border-gray-300 p-8 md:p-10 flex flex-col justify-center shadow-sm">
						<div class="font-mono text-xs text-nothing-red tracking-widest uppercase mb-6">[ 01_Profile ]</div>
						<h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mb-4 leading-tight">Kovács János</h1>
						<p class="font-sans text-base text-gray-700 leading-relaxed mb-8">
							Full Stack fejlesztő.<br />
							A tiszta kód és a skálázható rendszerek megszállottja.
						</p>
						<div class="font-mono text-[10px] md:text-xs text-gray-400 pt-4 border-t border-gray-200 mt-auto">
							ID: DEV_KJ_88 // LOC: Budapest
						</div>
					</div>

					<div class="bg-gray-100 border border-gray-300 flex items-center justify-center overflow-hidden shadow-sm relative">
						<ProfileHologram client:only="react" />
					</div>

					<div class="bg-white/60 backdrop-blur-md border border-gray-300 p-8 md:p-10 flex flex-col justify-between shadow-sm relative overflow-hidden group">
						<div class="font-mono text-xs text-gray-400 tracking-widest uppercase relative z-10 mb-8">[ Status ]</div>
						
						<div class="absolute right-[-10%] top-1/2 -translate-y-1/2 w-[250px] md:w-[350px] h-[250px] md:h-[350px] opacity-60 group-hover:opacity-100 transition-opacity pointer-events-none">
							<SystemCore client:only="react" />
						</div>

						<div class="relative z-10 mt-auto">
							<div class="font-serif text-3xl md:text-4xl mb-4 leading-tight">Available<br />for Work</div>
							<div class="flex items-center gap-2 mb-6">
								<div class="w-2 h-2 rounded-full bg-nothing-red animate-pulse"></div>
								<span class="font-mono text-xs tracking-widest text-gray-500 uppercase">Core Active</span>
							</div>
							<a href="mailto:email@cim.hu" class="font-mono text-xs md:text-sm border-b border-black pb-1 hover:text-nothing-red hover:border-nothing-red transition-colors inline-block">
								[ CONTACT_ME ]
							</a>
						</div>
					</div>

				</div>
			</section>

			<section class="min-h-[100dvh] w-full bg-black text-white flex items-center justify-center p-6 md:p-12 relative overflow-hidden">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-5 font-serif text-[15vw] leading-none pointer-events-none whitespace-nowrap">
					PROJECTS
				</div>
				
				<div class="max-w-7xl w-full relative z-10 flex flex-col justify-center py-12">
					<div class="font-mono text-xs text-gray-400 tracking-widest uppercase mb-12 text-center">[ 02_Projects_Hub ]</div>
					
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
						<a href="#" class="block border border-gray-700 p-8 hover:bg-white/10 transition-colors group">
							<h3 class="font-mono text-xl md:text-2xl mb-4 text-white group-hover:text-nothing-red transition-colors">Angular.App</h3>
							<p class="font-sans text-sm text-gray-400 mb-8">Komplex kliensoldali SPA architektúra RxJS-sel.</p>
							<span class="text-xs font-mono text-gray-500 group-hover:text-white transition-colors">LAUNCH -></span>
						</a>
						<a href="#" class="block border border-gray-700 p-8 hover:bg-white/10 transition-colors group">
							<h3 class="font-mono text-xl md:text-2xl mb-4 text-white group-hover:text-nothing-red transition-colors">React.Shop</h3>
							<p class="font-sans text-sm text-gray-400 mb-8">Modern e-kereskedelmi felület, gyors állapotkezeléssel.</p>
							<span class="text-xs font-mono text-gray-500 group-hover:text-white transition-colors">LAUNCH -></span>
						</a>
						<a href="#" class="block border border-gray-700 p-8 hover:bg-white/10 transition-colors group">
							<h3 class="font-mono text-xl md:text-2xl mb-4 text-white group-hover:text-nothing-red transition-colors">Blazor.CRM</h3>
							<p class="font-sans text-sm text-gray-400 mb-8">Teljes C# stacken futó belső ügyviteli rendszer.</p>
							<span class="text-xs font-mono text-gray-500 group-hover:text-white transition-colors">LAUNCH -></span>
						</a>
					</div>
				</div>
			</section>

			<section class="min-h-[100dvh] w-full flex items-center justify-center p-6 md:p-12">
				<div class="max-w-5xl w-full bg-white/60 backdrop-blur-md border border-gray-300 p-10 md:p-16 shadow-sm text-center">
					<div class="font-mono text-xs text-nothing-red tracking-widest uppercase mb-10">[ 03_Tech_Stack ]</div>
					
					<div class="flex flex-wrap justify-center gap-4 md:gap-6 font-sans text-sm md:text-base">
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">Angular (RxJS, NgRx)</span>
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">React (Next.js)</span>
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">Tailwind CSS</span>
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">C# .NET 8</span>
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">ASP.NET Core / Blazor</span>
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">SQL / PostgreSQL</span>
						<span class="border border-gray-300 px-5 py-3 bg-white hover:border-nothing-red transition-colors cursor-default">Docker & CI/CD</span>
					</div>
				</div>
			</section>

			<section class="min-h-[100dvh] w-full flex items-center justify-center p-6 md:p-12">
				<div class="max-w-7xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
					
					<div class="bg-white/60 backdrop-blur-md border border-gray-300 p-8 md:p-12 shadow-sm flex flex-col justify-center">
						<div class="font-mono text-xs text-nothing-red tracking-widest uppercase mb-10">[ 04_Experience ]</div>
						
						<div class="border-l border-black pl-5 mb-8 relative">
							<div class="absolute w-2 h-2 bg-black rounded-full -left-[4.5px] top-1.5"></div>
							<h3 class="font-bold text-xl md:text-2xl mb-1">Full Stack Fejlesztő</h3>
							<div class="text-xs font-mono text-gray-500 mb-3">Példa Kft. | 2022 - Jelenleg</div>
							<p class="text-sm md:text-base text-gray-700 font-sans leading-relaxed">
								Belső ERP rendszer fejlesztése és mikroszervizek tervezése. Modern interaktív felületek építése.
							</p>
						</div>

						<div class="border-l border-gray-300 pl-5 relative">
							<div class="absolute w-2 h-2 bg-gray-300 rounded-full -left-[4.5px] top-1.5"></div>
							<h3 class="font-bold text-xl md:text-2xl text-gray-600 mb-1">Junior Fejlesztő</h3>
							<div class="text-xs font-mono text-gray-400 mb-3">Startup Zrt. | 2020 - 2022</div>
							<p class="text-sm md:text-base text-gray-500 font-sans leading-relaxed">
								Webes felületek készítése Blazorral, adatbázisok tervezése.
							</p>
						</div>
					</div>

					<div class="flex flex-col gap-8 md:gap-12">
						<div class="bg-white/20 backdrop-blur-sm border border-gray-300 border-dashed p-8 md:p-12 flex flex-col justify-center items-start shadow-sm flex-1">
							<div class="font-mono text-xs text-gray-500 tracking-widest uppercase mb-4">[ 05_Education ]</div>
							<h3 class="font-serif text-2xl md:text-3xl mb-2">Mérnökinformatikus BSc</h3>
							<p class="font-mono text-xs text-gray-500">Neumann János Egyetem (2017-2021)</p>
						</div>
						
						<div class="bg-white/20 backdrop-blur-sm border border-gray-300 border-dashed p-8 md:p-12 flex flex-col justify-center items-start shadow-sm flex-1">
							<div class="font-mono text-xs text-gray-500 tracking-widest uppercase mb-4">[ 06_Hobbies ]</div>
							<h3 class="font-serif text-2xl md:text-3xl mb-2">3D Nyomtatás & Természet</h3>
							<p class="font-mono text-xs text-gray-500">A hardver és a világ felfedezése.</p>
						</div>
					</div>

				</div>
			</section>

		</main>
	</body>
</html>